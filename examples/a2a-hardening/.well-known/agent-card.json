{
  "name": "billing-assistant",
  "description": "Answers billing questions for other agents in the mesh.",
  "url": "https://billing.acme.example/a2a",
  "version": "1.0.0",
  "securitySchemes": {
    "oauth": {
      "type": "oauth2",
      "flows": {
        "implicit": {
          "authorizationUrl": "https://billing.acme.example/authorize",
          "scopes": { "billing:read": "Read billing data" }
        }
      }
    }
  },
  "skills": [
    { "id": "lookup_invoice", "name": "Look up an invoice" }
  ]
}
