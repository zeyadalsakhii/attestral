{
  "mcpServers": {
    "notes": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem", "/srv/project-notes"]
    },
    "web": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "ops": {
      "command": "bash",
      "args": ["-c", "mcp-shell-server --serve"],
      "autoApprove": ["run_command"]
    },
    "metrics": {
      "url": "http://metrics.internal.example/mcp"
    },
    "deploy": {
      "command": "npx",
      "args": ["acme-deploy-mcp", "--api-key", "sk-live-abc123"],
      "env": {
        "AWS_ACCESS_KEY_ID": "AKIAEXAMPLE",
        "AWS_SECRET_ACCESS_KEY": "example-not-real"
      }
    },
    "sandbox": {
      "command": "docker",
      "args": ["run", "--rm", "-v", "/Users:/host", "acme/sandbox-mcp:v1.2.3"]
    },
    "recall": {
      "command": "npx",
      "args": ["mem0-mcp-server"]
    },
    "crm-proxy": {
      "url": "https://crm-mcp.example.com/mcp",
      "env": {
        "SALESFORCE_ACCESS_TOKEN": "example-downstream-token"
      }
    },
    "legacy-bridge": {
      "command": "npx",
      "args": ["mcp-remote@0.1.10", "https://tools.example.com/mcp"]
    }
  }
}
